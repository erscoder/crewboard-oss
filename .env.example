DATABASE_URL=postgresql://your_user@localhost:5432/crewboard

# GitHub OAuth — create at github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:3020/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord Bot — create at discord.com/developers/applications
# Callback URL: http://localhost:3020/api/discord/callback
# Bot permissions needed: Send Messages (2048)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# Telegram Bot — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Slack App — create at api.slack.com/apps
# Redirect URL: http://localhost:3020/api/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Base URL (used for OAuth redirect URIs)
NEXTAUTH_URL=http://localhost:3020

# OpenClaw Gateway — required for agent triggering and /agents page
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=YOUR_GATEWAY_TOKEN

# Optional: openclaw.json path — defaults to ~/.openclaw/openclaw.json
# OPENCLAW_CONFIG_PATH=/your_openclaw_path/openclaw.json

PORT=3020
